# Admin Service Port (default: 4000)
ADMIN_PORT=4000
NODE_ENV=development

# Supabase (same DB as gateway)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Admin API Key (must match gateway's ADMIN_API_KEY)
ADMIN_API_KEY=your-admin-api-key

# Secret path for internal Swagger docs
INTERNAL_DOCS_PATH=/ref-changeme

# Gateway URL (for platform health checks)
GATEWAY_URL=http://localhost:3000

# SMTP (optional, for email notifications)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000
